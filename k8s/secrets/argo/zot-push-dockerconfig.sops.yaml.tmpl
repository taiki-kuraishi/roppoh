# ⚠️ TEMPLATE — auth を base64("ci:<password>") に置き換え（zot-htpasswd と同じ password）、
#    `sops -e -i k8s/secrets/argo/zot-push-dockerconfig.sops.yaml` で暗号化してからコミットすること。
# kaniko が /kaniko/.docker/config.json として読み、zot へ push 認証する。
apiVersion: v1
kind: Secret
metadata:
  name: zot-push-dockerconfig
  namespace: argo
type: Opaque
stringData:
  config.json: |
    {
      "auths": {
        "zot.zot.svc.cluster.local:5000": {
          "auth": "REPLACE_ME_BASE64_OF_ci_COLON_password"
        }
      }
    }
