# ⚠️ TEMPLATE — Renovate の GitHub App 値（renovate/renovate-github-app.sops.yaml と同値）を入れ、
#    `sops -e -i k8s/secrets/argo/build-github-app.sops.yaml` で暗号化してからコミットすること。
# CronWorkflow の bump ステップが JWT→installation token を生成して main へ commit-back する。
apiVersion: v1
kind: Secret
metadata:
  name: build-github-app
  namespace: argo
type: Opaque
stringData:
  app-id: "REPLACE_ME_APP_ID"
  installation-id: "REPLACE_ME_INSTALLATION_ID"
  private-key.pem: |
    -----BEGIN RSA PRIVATE KEY-----
    REPLACE_ME
    -----END RSA PRIVATE KEY-----
