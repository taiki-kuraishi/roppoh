# ⚠️ TEMPLATE — 実値に置き換え、`sops -e -i k8s/secrets/discord-gateway-proxy/discord-gateway-proxy.sops.yaml`
#    で暗号化してからコミットすること（平文の実シークレットをコミットしない）。
# - bot-token : Discord Bot トークン（ローカルの cmd/discord-gateway-proxy/.env.sops.yaml と同値）
# - otlp-token: alloy の bearer 認証トークン（monitoring/cf-workers-otlp-token と同値）
apiVersion: v1
kind: Secret
metadata:
  name: discord-gateway-proxy
  namespace: discord-gateway-proxy
type: Opaque
stringData:
  bot-token: REPLACE_ME_DISCORD_BOT_TOKEN
  otlp-token: REPLACE_ME_OTLP_BEARER_TOKEN
