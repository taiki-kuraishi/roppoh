# ⚠️ TEMPLATE — R2 アクセスキーを入れ、
#    `sops -e -i k8s/secrets/zot/zot-object-storage.sops.yaml` で暗号化してからコミットすること。
# grafana-object-storage と同じ R2 トークンが roppoh-zot バケットにアクセス可なら同値でよい。
apiVersion: v1
kind: Secret
metadata:
  name: zot-object-storage
  namespace: zot
type: Opaque
stringData:
  AWS_ACCESS_KEY_ID: REPLACE_ME_R2_ACCESS_KEY_ID
  AWS_SECRET_ACCESS_KEY: REPLACE_ME_R2_SECRET_ACCESS_KEY
