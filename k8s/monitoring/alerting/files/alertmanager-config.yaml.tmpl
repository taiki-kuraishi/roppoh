# __DISCORD_WEBHOOK_URL__ は bootstrap-job.yaml が sed で実値に置換してから
# mimirtool alertmanager load に渡す(Secret の値を ConfigMap に直接書けないため)。
route:
  receiver: discord
  group_by: [alertname, namespace]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
receivers:
  - name: discord
    discord_configs:
      - webhook_url: "__DISCORD_WEBHOOK_URL__"
