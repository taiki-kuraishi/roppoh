{
  "timezone": "browser",
  "editable": false,
  "graphTooltip": 0,
  "fiscalYearStartMonth": 0,
  "schemaVersion": 41,
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "skipUrlSync": false,
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "label": "Data source",
        "query": "prometheus",
        "current": {
          "text": "Mimir",
          "value": "mimir",
          "selected": true
        }
      }
    ]
  },
  "annotations": {},
  "title": "Monitoring / Observability stack",
  "uid": "roppoh-observability-stack",
  "description": "可観測性パイプライン自身 (Alloy/Grafana) の健全性。Mimir/Loki/Tempo のメトリクス self-scrape はフォローアップ課題",
  "tags": ["generated", "monitoring", "self-monitoring"],
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "Alloy",
      "gridPos": {
        "x": 0,
        "y": 0,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "stat",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Alloy up",
      "description": "self-scrape ターゲットの生存 (1=up)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "up{job=\"alloy\"}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 1
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Alloy component evaluation",
      "description": "コンポーネント評価の所要時間 (p99)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (node, le) (rate(alloy_component_evaluation_seconds_bucket{job=\"alloy\"}[$__rate_interval])))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "legendFormat": "{{node}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 1
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Alloy Prometheus remote_write failures",
      "description": "remote_write の失敗サンプル数 (増加していれば push 先が壊れている可能性、Phase 1 で見つかった404はこれで検知できたはず)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (node, reason) (rate(prometheus_remote_storage_samples_failed_total{job=\"alloy\"}[$__rate_interval]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "legendFormat": "{{node}} / {{reason}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 10
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Alloy Loki send failures",
      "description": "Loki への書き込み失敗数",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (node) (rate(loki_write_dropped_bytes_total{job=\"alloy\"}[$__rate_interval]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "legendFormat": "{{node}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 10
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "Grafana",
      "gridPos": {
        "x": 0,
        "y": 19,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "stat",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Grafana up",
      "description": "self-scrape ターゲットの生存 (1=up)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "up{job=\"grafana\"}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 20
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Grafana HTTP request duration (p99)",
      "description": "Grafana API/UI のリクエスト所要時間",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (handler, le) (rate(grafana_http_request_duration_seconds_bucket{job=\"grafana\"}[$__rate_interval])))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "legendFormat": "{{handler}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 20
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "Logs (Mimir / Loki / Tempo)",
      "gridPos": {
        "x": 0,
        "y": 29,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "logs",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Mimir error logs",
      "description": "grafana-mimir-* 全コンポーネントの error ログ",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showLabels": false,
        "showCommonLabels": false,
        "showTime": true,
        "showLogContextToggle": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{namespace=\"monitoring\", pod=~\"grafana-mimir-.*\"} |~ \"(?i)error\"",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "maxLines": 200
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 30
      }
    },
    {
      "type": "logs",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Loki / Tempo error logs",
      "description": "grafana-loki / grafana-tempo の error ログ",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showLabels": false,
        "showCommonLabels": false,
        "showTime": true,
        "showLogContextToggle": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{namespace=\"monitoring\", pod=~\"grafana-loki-.*|grafana-tempo-.*\"} |~ \"(?i)error\"",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "maxLines": 200
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 30
      }
    }
  ]
}
