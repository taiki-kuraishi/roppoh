{
  "timezone": "browser",
  "editable": false,
  "graphTooltip": 0,
  "fiscalYearStartMonth": 0,
  "schemaVersion": 41,
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "skipUrlSync": false,
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "label": "Data source",
        "query": "prometheus",
        "current": {
          "text": "Mimir",
          "value": "mimir",
          "selected": true
        }
      }
    ]
  },
  "annotations": {},
  "title": "Applications / Traefik ingress",
  "uid": "roppoh-traefik-ingress",
  "description": "Traefik (k3s 標準 ingress) のリクエストレート/レイテンシ/ステータス",
  "tags": [
    "generated",
    "applications",
    "traefik"
  ],
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "Entrypoints",
      "gridPos": {
        "x": 0,
        "y": 0,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Request rate by entrypoint",
      "description": "entrypoint (web/websecure 等) 別リクエストレート",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (entrypoint, code) (rate(traefik_entrypoint_requests_total{namespace=\"kube-system\", job=~\"kube-system/traefik.*\"}[$__rate_interval]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "legendFormat": "{{entrypoint}} / {{code}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 1
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Request duration (p99) by entrypoint",
      "description": "entrypoint 別リクエスト所要時間 (p99)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (entrypoint, le) (rate(traefik_entrypoint_request_duration_seconds_bucket{namespace=\"kube-system\", job=~\"kube-system/traefik.*\"}[$__rate_interval])))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "legendFormat": "{{entrypoint}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 1
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "Services & routers",
      "gridPos": {
        "x": 0,
        "y": 10,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Request rate by service",
      "description": "バックエンド service 別リクエストレート",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (service, code) (rate(traefik_service_requests_total{namespace=\"kube-system\", job=~\"kube-system/traefik.*\"}[$__rate_interval]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "legendFormat": "{{service}} / {{code}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 11
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "5xx rate by service",
      "description": "バックエンド service 別 5xx エラーレート",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(traefik_service_requests_total{namespace=\"kube-system\", job=~\"kube-system/traefik.*\", code=~\"5..\"}[$__rate_interval]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "legendFormat": "{{service}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 11
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Router request rate",
      "description": "router 別リクエストレート",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (router) (rate(traefik_router_requests_total{namespace=\"kube-system\", job=~\"kube-system/traefik.*\"}[$__rate_interval]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "legendFormat": "{{router}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 20
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "Logs",
      "gridPos": {
        "x": 0,
        "y": 29,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "logs",
      "transparent": false,
      "repeatDirection": "h",
      "title": "traefik logs",
      "description": "traefik コンテナのログ (エラー含む)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showLabels": false,
        "showCommonLabels": false,
        "showTime": true,
        "showLogContextToggle": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{namespace=\"kube-system\", container=\"traefik\"}",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "maxLines": 200
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 30
      }
    }
  ]
}
