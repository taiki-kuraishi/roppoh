{
  "timezone": "browser",
  "editable": false,
  "graphTooltip": 0,
  "fiscalYearStartMonth": 0,
  "schemaVersion": 41,
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "skipUrlSync": false,
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "label": "Data source",
        "query": "prometheus",
        "current": {
          "text": "Mimir",
          "value": "mimir",
          "selected": true
        }
      }
    ]
  },
  "annotations": {},
  "title": "Applications / discord-gateway-proxy",
  "uid": "roppoh-discord-gateway-proxy",
  "description": "discord-gateway-proxy (z390) のログと Go runtime メトリクス。ビジネスメトリクス/トレースは現状未計装",
  "tags": ["generated", "applications", "discord-gateway-proxy"],
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "Logs",
      "gridPos": {
        "x": 0,
        "y": 0,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Log volume",
      "description": "ログ件数レート",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=\"discord-gateway-proxy\"} [$__auto]))",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "legendFormat": "logs"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 1
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Error/warn rate",
      "description": "error/warn を含む行のレート (JSON レベルフィールドに依存しない行フィルタ)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=\"discord-gateway-proxy\"} |~ \"(?i)error|warn\" [$__auto]))",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "legendFormat": "matches"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 1
      }
    },
    {
      "type": "logs",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Recent logs",
      "description": "直近のログ (OTel LogRecord 形式の JSON)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showLabels": false,
        "showCommonLabels": false,
        "showTime": true,
        "showLogContextToggle": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{namespace=\"discord-gateway-proxy\"} | json",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "maxLines": 200
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 10
      }
    },
    {
      "type": "logs",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Error logs",
      "description": "error/warn を含むログ",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showLabels": false,
        "showCommonLabels": false,
        "showTime": true,
        "showLogContextToggle": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{namespace=\"discord-gateway-proxy\"} |~ \"(?i)error|warn\"",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "maxLines": 200
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 10
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "Go runtime (参考、単位サフィックスは要確認)",
      "gridPos": {
        "x": 0,
        "y": 19,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Goroutines",
      "description": "稼働中の goroutine 数 (go.goroutine.count)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "go_goroutine_count{job=\"discord/discord-gateway-proxy\"}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "legendFormat": "goroutines"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 20
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Memory used",
      "description": "Go ランタイムが使用するメモリ (go.memory.used, 内訳: go_memory_type)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "go_memory_used_bytes{job=\"discord/discord-gateway-proxy\"}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "legendFormat": "{{go_memory_type}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 20
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Heap allocation rate",
      "description": "ヒープアロケーションのレート (go.memory.allocated)。GC 実行回数 (cycles) 自体は go.opentelemetry.io/contrib/instrumentation/runtime が現状エクスポートしないため、 GC 負荷の代理指標として用いる",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(go_memory_allocated_bytes_total{job=\"discord/discord-gateway-proxy\"}[$__rate_interval])",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "legendFormat": "allocated"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 29
      }
    }
  ]
}
