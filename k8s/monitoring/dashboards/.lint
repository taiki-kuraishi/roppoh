# grafana/dashboard-linter 設定
# https://github.com/grafana/dashboard-linter
#
# dashboard-linter は「アプリ/サービス監視」向けに job / instance テンプレ変数を
# 強制するが、このリポジトリのダッシュボードは job を固定文字列で直接指定する
# (kubernetes-cadvisor / kubelet / node-exporter / kube-state-metrics 等) ため
# $job 変数は不要。instance は Phase 1 で node 別に区別できるよう修正したが、
# 本リポジトリでは "$instance" ではなく可読性の高い独自の "$node" 変数名を
# 使っているため、慣習的な instance 変数/マッチャの要求は除外する。
exclusions:
  template-job-rule:
    reason: "job は固定文字列で直接指定しており $job 変数は不要"
  template-instance-rule:
    reason: "instance ではなく独自の $node 変数 (node ラベル) を使っている"
  target-job-rule:
    reason: "固定 job (kubernetes-cadvisor 等) を直接指定しており $job マッチャは使わない"
  target-instance-rule:
    reason: "instance ではなく node ラベル/$node 変数でノードを絞り込んでいる"
  # 以下は Loki/Tempo ダッシュボード (cf-workers-otel) 向け。dashboard-linter は
  # Prometheus 前提で datasource テンプレ変数を要求するが、Loki/Tempo は各 1 つで
  # UID 直指定のため不要。共有 .lint なので K8s 1 枚目にも適用されるが、1 枚目は
  # 元々 datasource 変数を持つので実害はない。
  template-datasource-rule:
    reason: "Loki/Tempo ダッシュボードは datasource が単一・UID 直指定で変数化しない"
  panel-datasource-rule:
    reason: "Loki/Tempo パネルは UID 直指定。Prometheus datasource 変数は持たない"
  # Prometheus ($datasource) と Loki を同一ダッシュボードに混在させる場合
  # (discord-gateway-proxy 等)、dashboard-linter は Prometheus テンプレ変数の
  # 存在だけを見て全 timeseries パネルを無条件に PromQL として検証してしまい、
  # LogQL の行フィルタ (`|~`) を構文エラーと誤検知する
  # (lint/rule_target_promql.go: getTemplateDatasource(d).Query != Prometheus
  # でのみスキップし、パネル個別の datasource は見ていないため)。
  target-promql-rule:
    reason: "Prometheus + Loki 混在ダッシュボードで LogQL パネルが誤って PromQL として検証されるため"
  # stat/table パネルで「選択範囲全体の合計」を意図的に示すため [$__range] を
  # 使っている箇所がある (例: 直近1時間の総ログ行数)。$__auto はグラフ描画用に
  # 解像度を自動調整するもので、このような単一値の集計には意味が異なる。
  target-logql-auto-rule:
    reason: "stat/table で選択範囲全体の合計を示すため意図的に $__range を使用 (グラフの $__auto とは用途が異なる)"
