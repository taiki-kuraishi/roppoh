{
  "timezone": "browser",
  "editable": false,
  "graphTooltip": 0,
  "fiscalYearStartMonth": 0,
  "schemaVersion": 41,
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "skipUrlSync": false,
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "label": "Data source",
        "query": "prometheus",
        "current": {
          "text": "Mimir",
          "value": "mimir",
          "selected": true
        }
      },
      {
        "type": "query",
        "name": "node",
        "skipUrlSync": false,
        "multi": true,
        "allowCustomValue": true,
        "includeAll": true,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "label": "Node",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(up{job=\"kubernetes-cadvisor\"}, node)",
        "refresh": 2,
        "sort": 1
      },
      {
        "type": "query",
        "name": "namespace",
        "skipUrlSync": false,
        "multi": true,
        "allowCustomValue": true,
        "includeAll": true,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "label": "Namespace",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(job=\"kubernetes-cadvisor\", container!=\"\", namespace)",
        "refresh": 2,
        "sort": 1
      },
      {
        "type": "query",
        "name": "pod",
        "skipUrlSync": false,
        "multi": true,
        "allowCustomValue": true,
        "includeAll": true,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "label": "Pod",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(container_cpu_usage_seconds_total{job=\"kubernetes-cadvisor\", namespace=~\"$namespace\", node=~\"$node\"}, pod)",
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "annotations": {},
  "title": "Kubernetes / Pods & Containers",
  "uid": "roppoh-k8s-pods",
  "description": "cAdvisor + kubelet メトリクス (Mimir) による Pod / コンテナ / ノード単位のリソース可視化",
  "tags": ["generated", "kubernetes", "cadvisor"],
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "Cluster overview",
      "gridPos": {
        "x": 0,
        "y": 0,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "stat",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Namespaces",
      "description": "メトリクスを出している namespace 数",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "count(count by (namespace) (container_cpu_usage_seconds_total{job=\"kubernetes-cadvisor\", container!=\"\", node=~\"$node\"}))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 1
      }
    },
    {
      "type": "stat",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Running pods",
      "description": "稼働中の Pod 数 (cAdvisor が観測している実コンテナ持ち)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "count(count by (namespace, pod) (container_cpu_usage_seconds_total{job=\"kubernetes-cadvisor\", container!=\"\", node=~\"$node\"}))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 1
      }
    },
    {
      "type": "stat",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Running containers",
      "description": "稼働中のコンテナ数",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "count(count by (namespace, pod, container) (container_cpu_usage_seconds_total{job=\"kubernetes-cadvisor\", container!=\"\", node=~\"$node\"}))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 10
      }
    },
    {
      "type": "stat",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Cluster CPU (cores)",
      "description": "選択ノードの CPU 使用量 (コア換算)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{job=\"kubernetes-cadvisor\", container!=\"\", node=~\"$node\"}[$__rate_interval]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 10
      }
    },
    {
      "type": "stat",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Cluster memory (working set)",
      "description": "選択ノードのメモリ working set",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
