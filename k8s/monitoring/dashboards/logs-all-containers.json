{
  "timezone": "browser",
  "editable": false,
  "graphTooltip": 0,
  "fiscalYearStartMonth": 0,
  "schemaVersion": 41,
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "namespace",
        "skipUrlSync": false,
        "multi": true,
        "allowCustomValue": true,
        "includeAll": true,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "label": "Namespace",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(namespace)",
        "refresh": 2,
        "sort": 1
      },
      {
        "type": "query",
        "name": "container",
        "skipUrlSync": false,
        "multi": true,
        "allowCustomValue": true,
        "includeAll": true,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "label": "Container",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values({namespace=~\"$namespace\"}, container)",
        "refresh": 2,
        "sort": 1
      },
      {
        "type": "query",
        "name": "node",
        "skipUrlSync": false,
        "multi": true,
        "allowCustomValue": true,
        "includeAll": true,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "label": "Node",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(node)",
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "annotations": {},
  "title": "Logs / All containers",
  "uid": "roppoh-logs-all-containers",
  "description": "全 namespace/Pod/コンテナのログ (Loki, pod-tail)。Cloudflare Workers の OTLP ログは Cloudflare フォルダの cf-workers-otel を参照",
  "tags": [
    "generated",
    "logs",
    "loki"
  ],
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "Overview",
      "gridPos": {
        "x": 0,
        "y": 0,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "stat",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Log volume (1h)",
      "description": "選択範囲の総ログ行数",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\"$namespace\", container=~\"$container\", node=~\"$node\"} [$__range]))",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "instant": true
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 1
      }
    },
    {
      "type": "stat",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Error/warn lines (1h)",
      "description": "error/warn/fatal を含む行数 (大文字小文字を区別しない)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\"$namespace\", container=~\"$container\", node=~\"$node\"} |~ \"(?i)error|warn|fatal\" [$__range]))",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "instant": true
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 1
      }
    },
    {
      "type": "table",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Top namespaces by volume",
      "description": "ログ量上位 10 namespace",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "topk(10, sum by (namespace) (count_over_time({namespace=~\".+\"} [$__range])))",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "instant": true
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 10
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "Volume & errors",
      "gridPos": {
        "x": 0,
        "y": 19,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Log volume by namespace",
      "description": "namespace 別ログ量レート",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (namespace) (count_over_time({namespace=~\"$namespace\", container=~\"$container\", node=~\"$node\"} [$__auto]))",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "legendFormat": "{{namespace}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 20
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Error/warn rate by namespace",
      "description": "error/warn/fatal を含む行のレート",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (namespace) (count_over_time({namespace=~\"$namespace\", container=~\"$container\", node=~\"$node\"} |~ \"(?i)error|warn|fatal\" [$__auto]))",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "legendFormat": "{{namespace}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 20
      }
    },
    {
      "type": "table",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Top error-producing pods",
      "description": "error/warn/fatal 行数が多い Pod (上位10)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "topk(10, sum by (namespace, pod) (count_over_time({namespace=~\"$namespace\", container=~\"$container\", node=~\"$node\"} |~ \"(?i)error|warn|fatal\" [$__range])))",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "instant": true
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 29
      }
    },
    {
