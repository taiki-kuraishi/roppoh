{
  "timezone": "browser",
  "editable": false,
  "graphTooltip": 0,
  "fiscalYearStartMonth": 0,
  "schemaVersion": 41,
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "skipUrlSync": false,
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "label": "Data source",
        "query": "prometheus",
        "current": {
          "text": "Mimir",
          "value": "mimir",
          "selected": true
        }
      }
    ]
  },
  "annotations": {},
  "title": "Applications / ArgoCD (GitOps)",
  "uid": "roppoh-argocd-gitops",
  "description": "ArgoCD 自身の Application 同期状態/health、リコンサイル頻度、repo-server の Git 操作",
  "tags": ["generated", "applications", "argocd", "gitops"],
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "Application health",
      "gridPos": {
        "x": 0,
        "y": 0,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "stat",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Apps out of sync",
      "description": "sync_status が Synced 以外の Application 数",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "count(argocd_app_info{job=\"argocd-application-controller\", sync_status!=\"Synced\"})",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 1
      }
    },
    {
      "type": "stat",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Apps unhealthy",
      "description": "health_status が Healthy 以外の Application 数",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "count(argocd_app_info{job=\"argocd-application-controller\", health_status!=\"Healthy\"})",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 1
      }
    },
    {
      "type": "stat",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Total apps",
      "description": "管理下の Application 数",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "count(argocd_app_info{job=\"argocd-application-controller\"})",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 10
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "Sync / reconcile",
      "gridPos": {
        "x": 0,
        "y": 19,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "App sync status by app",
      "description": "Application 別の sync/health 状態 (1=該当)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "argocd_app_info{job=\"argocd-application-controller\"}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "legendFormat": "{{name}} / {{sync_status}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 20
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Reconcile duration (p99)",
      "description": "Application リコンサイル所要時間 (p99)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(argocd_app_reconcile_bucket{job=\"argocd-application-controller\"}[$__rate_interval])))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "legendFormat": "reconcile"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 20
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Reconcile count",
      "description": "リコンサイル実行回数のレート",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(argocd_app_reconcile_count{job=\"argocd-application-controller\"}[$__rate_interval]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "legendFormat": "reconcile"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 29
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "Repo server (Git)",
      "gridPos": {
        "x": 0,
        "y": 38,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Git request duration (p99)",
      "description": "repo-server の Git 操作 (fetch/ls-remote 等) 所要時間",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (repo, request_type, le) (rate(argocd_git_request_duration_seconds_bucket{job=\"argocd-repo-server\"}[$__rate_interval])))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "legendFormat": "{{repo}} / {{request_type}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 39
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Git request rate",
      "description": "repo-server の Git 操作レート",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (repo, request_type) (rate(argocd_git_request_total{job=\"argocd-repo-server\"}[$__rate_interval]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "legendFormat": "{{repo}} / {{request_type}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 39
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "Logs",
      "gridPos": {
        "x": 0,
        "y": 48,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "logs",
      "transparent": false,
      "repeatDirection": "h",
      "title": "argocd-application-controller logs",
      "description": "sync/reconcile のイベントログ (JSON 構造化)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showLabels": false,
        "showCommonLabels": false,
        "showTime": true,
        "showLogContextToggle": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{namespace=\"argocd\", container=\"application-controller\"} | json",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "maxLines": 200
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 49
      }
    },
    {
      "type": "logs",
      "transparent": false,
      "repeatDirection": "h",
      "title": "argocd error logs (all components)",
      "description": "argocd namespace 全体の error ログ",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showLabels": false,
        "showCommonLabels": false,
        "showTime": true,
        "showLogContextToggle": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{namespace=\"argocd\"} | json | level=\"error\"",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "maxLines": 200
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 49
      }
    }
  ]
}
