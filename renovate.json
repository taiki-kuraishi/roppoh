{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "ignorePaths": ["k8s/argocd/install.yaml"],
  "commitMessagePrefix": "⬆️ ",
  "labels": ["dependencies"],
  "kubernetes": {
    "fileMatch": ["(^|/)k8s/.+\\.ya?ml$"]
  },
  "argocd": {
    "fileMatch": ["k8s/argocd/apps/.+\\.ya?ml$"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^\\.docker/playwright/Dockerfile$"],
      "matchStrings": ["FROM mcr\\.microsoft\\.com/playwright:v(?<currentValue>[\\d.]+)-noble"],
      "depNameTemplate": "@playwright/test",
      "datasourceTemplate": "npm"
    },
    {
      "customType": "regex",
      "fileMatch": ["^\\.docker/playwright/Dockerfile$"],
      "matchStrings": ["COPY --from=oven/bun:(?<currentValue>[\\d.]+) "],
      "depNameTemplate": "bun",
      "datasourceTemplate": "npm"
    },
    {
      "customType": "regex",
      "fileMatch": ["^package\\.json$"],
      "matchStrings": ["\"packageManager\":\\s*\"bun@(?<currentValue>[\\d.]+)\""],
      "depNameTemplate": "bun",
      "datasourceTemplate": "npm"
    },
    {
      "customType": "regex",
      "fileMatch": ["^mise\\.toml$"],
      "matchStrings": ["\"npm:turbo\"\\s*=\\s*\"(?<currentValue>[\\d.]+)\""],
      "depNameTemplate": "turbo",
      "datasourceTemplate": "npm"
    },
    {
      "customType": "regex",
      "fileMatch": ["^\\.docker/discord-gateway-proxy/Dockerfile$"],
      "matchStrings": ["FROM golang:(?<currentValue>[\\d.]+)-bookworm"],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "matchManagers": ["github-actions"],
      "addLabels": ["github-actions"],
      "automerge": true
    },
    {
      "matchManagers": ["npm", "bun"],
      "addLabels": ["bun"],
      "minimumReleaseAge": "1 day"
    },
    {
      "matchManagers": ["dockerfile"],
      "addLabels": ["docker"],
      "automerge": true
    },
    {
      "matchManagers": ["docker-compose"],
      "addLabels": ["docker-compose"],
      "automerge": true
    },
    {
      "matchManagers": ["kubernetes"],
      "addLabels": ["kubernetes"]
    },
    {
      "matchManagers": ["argocd"],
      "addLabels": ["kubernetes", "helm"]
    },
    {
      "matchManagers": ["mise"],
      "addLabels": ["mise"]
    },
    {
      "matchPackageNames": ["turbo"],
      "groupName": "turbo"
    },
    {
      "matchPackageNames": ["bun"],
      "groupName": "bun",
      "automerge": true
    },
    {
      "matchPackageNames": ["@playwright/test", "playwright"],
      "groupName": "playwright",
      "automerge": true
    },
    {
      "matchDepNames": ["go"],
      "matchDatasources": ["golang-version"],
      "groupName": "go"
    },
    {
      "matchManagers": ["npm", "bun"],
      "matchPackageNames": ["react", "react-dom", "@types/react", "@types/react-dom"],
      "groupName": "react"
    },
    {
      "matchManagers": ["npm", "bun"],
      "matchPackageNames": [
        "vitest",
        "vitest-browser-react",
        "@vitest/ui",
        "@vitest/browser-playwright"
      ],
      "groupName": "vitest"
    }
  ]
}
