#!/usr/bin/env bash
#MISE description="Lint k8s manifests (kubeconform, kube-linter)"

set -euo pipefail

# patches/ holds Kustomize strategic-merge patches (partial resources);
# skip them so kubeconform doesn't reject them for missing required fields.
# dashboards/ holds generated Grafana dashboard JSON (not k8s manifests);
# files/ holds configMapGenerator source files (raw config, not k8s manifests);
# skip them so kubeconform doesn't try to validate them as resources.
kubeconform -summary -ignore-missing-schemas \
  -ignore-filename-pattern 'patches/' \
  -ignore-filename-pattern 'dashboards/' \
  -ignore-filename-pattern 'files/' \
  k8s

kube-linter lint k8s --config .kube-linter.yaml
