{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "compatibility_date": "2025-10-08",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "ROPPOH_BETTER_AUTH_DB",
      "database_id": "6d92a782-2699-4dd0-9d45-733c1f03b8f7",
      "database_name": "roppoh-better-auth",
      "migrations_dir": "../../packages/better-auth/src/migrations",
    },
  ],
  "main": "./src/server/entry.ts",
  "name": "neo-fujimatsu",
  "observability": { "enabled": true },
  "preview_urls": false,
  "vars": {
    "CORS_DOMAIN": "https://tsar-bmb.org",
    "DISCORD_CLIENT_ID": "1489801501307310202",
    "NODE_ENV": "production",
  },
  // wrangler.jsonc と同様、値は書かず名前だけ宣言する (実値は vitest.config.ts の
  // test.env / wrangler secret put 側で管理)
  "secrets": {
    "required": ["BETTER_AUTH_SECRET", "DISCORD_CLIENT_SECRET"],
  },
  "workers_dev": false,
}
