#!/usr/bin/env bash
# GitHub App の installation access token を stdout に出力する(bash + openssl +
# jq のみに依存。node は bootstrap 前に存在しないため使わない — roppoh-remote-dev-plan.md 参照)。
#
# Usage: gh-app-token [owner]
#   owner: tsar-org(既定)| taiki-kuraishi
set -euo pipefail

dir=/etc/remote-dev/github-app
owner="${1:-tsar-org}"

installation_id_file="$dir/installation-id-${owner}"
if [ ! -f "$installation_id_file" ]; then
  echo "gh-app-token: unknown owner '${owner}' (no ${installation_id_file})" >&2
  exit 1
fi

installation_id="$(cat "$installation_id_file")"
app_id="$(cat "$dir/app-id")"

b64url() { openssl base64 -A | tr '+/' '-_' | tr -d '='; }

now=$(date +%s)
header=$(printf '{"alg":"RS256","typ":"JWT"}' | b64url)
payload=$(printf '{"iat":%d,"exp":%d,"iss":"%s"}' "$((now - 60))" "$((now + 540))" "$app_id" | b64url)
sig=$(printf '%s.%s' "$header" "$payload" | openssl dgst -sha256 -sign "$dir/private-key.pem" -binary | b64url)

curl -fsS -X POST \
  -H "Authorization: Bearer $header.$payload.$sig" \
  -H "Accept: application/vnd.github+json" \
  -H "X-GitHub-Api-Version: 2022-11-28" \
  "https://api.github.com/app/installations/${installation_id}/access_tokens" | jq -r .token
