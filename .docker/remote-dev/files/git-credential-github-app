#!/usr/bin/env bash
# git credential helper: stdin の path= の先頭セグメントを owner とみなし、
# gh-app-token <owner> で発行した短命トークンを返す(roppoh-remote-dev-plan.md 参照)。
#
# `useHttpPath = true` により path が渡される前提(.gitconfig.local が設定する)。
set -euo pipefail

action="${1:-}"

# get 以外(store/erase)は何もせず正常終了
if [ "$action" != "get" ]; then
  exit 0
fi

path=""
while IFS='=' read -r key value; do
  [ -z "$key" ] && break
  if [ "$key" = "path" ]; then
    path="$value"
  fi
done

owner="${path%%/*}"

if [ -z "$owner" ]; then
  exit 0
fi

if ! token="$(gh-app-token "$owner" 2>/dev/null)"; then
  # installation が無い owner: 何も出力せず終了し、他の helper にフォールバックさせる
  exit 0
fi

printf 'username=x-access-token\n'
printf 'password=%s\n' "$token"
