#!/usr/bin/env bash
# claude コンテナのエントリポイント。claude 本体は dotfiles の bootstrap が
# インストールし、認証は初回に人間が
#   kubectl exec -it -n claude-remote-control claude-remote-control-0 -c claude -- claude auth login
# で行う。どちらも揃うまで待機し、CrashLoopBackOff にしない
# (roppoh-claude-remote-control-plan.md 参照)。
set -euo pipefail
export PATH="$HOME/.local/bin:$PATH"

until command -v claude >/dev/null 2>&1 && [ -f "$HOME/.claude/.credentials.json" ]; do
  echo "waiting for claude install + auth (see roppoh-claude-remote-control-plan.md)"
  sleep "${CLAUDE_WAIT_INTERVAL:-300}"
done

exec claude remote-control --spawn=worktree --name "roppoh-dev"
